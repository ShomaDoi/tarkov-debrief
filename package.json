{
  "name": "debrief",
  "version": "0.1.0",
  "homepage": "https://debrief.jrkt.dev",
  "private": true,
  "dependencies": {
    "fabric": "^7.3.1",
    "react": "^18.0.1",
    "react-color": "^2.19.3",
    "react-dom": "^18.0.1",
    "react-ga": "^3.3.0",
    "wouter": "^3.3.5"
  },
  "scripts": {
    "start": "vite",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "build": "tsc --noEmit && vite build",
    "predeploy": "vite build",
    "deploy": "gh-pages -d build"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.0.0",
    "@types/react": "^18.0.0",
    "@types/react-color": "^3.0.4",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^5.1.0",
    "@vitest/ui": "^4.1.5",
    "gh-pages": "^6.x",
    "jsdom": "^29.1.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.2",
    "vitest": "^4.1.5"
  }
}
